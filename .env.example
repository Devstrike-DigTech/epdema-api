# EPDEMA API env
# Copy to .env and fill in real values. Never commit .env.

NODE_ENV=development
PORT=3001

# ── Postgres
DATABASE_URL=postgres://epdema:epdema_dev@localhost:5432/epdema

# ── Redis
REDIS_URL=redis://localhost:6379

# ── Better Auth
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=replace-with-openssl-rand-hex-32
BETTER_AUTH_URL=http://localhost:3001

# ── CORS
WEB_ORIGIN=http://localhost:3000

# ── Paystack (test keys for local; live keys in Railway only)
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# ── Resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=EPDEMA <hello@epdema.com>

# ── Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ── Google Places
GOOGLE_PLACES_API_KEY=xxxxxxxxxxxxxxxxxxxx

# ── Observability (optional in dev — SDK no-ops when DSN is empty)
SENTRY_DSN=
# Defaults to `epdema-api@<package.json version>`; CI bumps to a git sha.
SENTRY_RELEASE=
LOG_LEVEL=debug

# ── Social auth (optional — Better Auth's socialProviders block only
#    registers a provider when its pair / quartet is set)
# Google: free. Cloud Console → APIs & Services → Credentials → OAuth client
# (Web app). Redirect URI for dev: http://localhost:3001/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple: $99/yr (Apple Developer Program). Identifiers → Services ID with
# Sign in with Apple enabled + a Key with the same capability (download the
# .p8 file → paste its contents into APPLE_PRIVATE_KEY with `\n` for newlines).
# Return URL for dev: http://localhost:3001/api/auth/callback/apple
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# ── Storage (Phase 5c·D — brand assets)
# `local` writes to api/storage/uploads and serves at <API_ORIGIN>/uploads/*.
# Switch to `s3` in any environment with more than one api replica.
STORAGE_DRIVER=local
API_ORIGIN=http://localhost:3001
# STORAGE_LOCAL_DIR=storage/uploads          # default
# STORAGE_LOCAL_PUBLIC_PREFIX=/uploads       # default

# Only required when STORAGE_DRIVER=s3 (AWS S3 / Cloudflare R2 / Backblaze B2):
# STORAGE_S3_BUCKET=epdema-uploads
# STORAGE_S3_REGION=auto                     # `auto` for R2, e.g. us-east-1 for AWS
# STORAGE_S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com    # omit for AWS
# STORAGE_S3_ACCESS_KEY_ID=
# STORAGE_S3_SECRET_ACCESS_KEY=
# STORAGE_S3_PUBLIC_BASE=https://cdn.epdema.com    # bucket public origin / CDN
