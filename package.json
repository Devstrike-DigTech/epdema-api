{
  "name": "epdema-api",
  "version": "0.1.0",
  "private": true,
  "description": "EPDEMA NestJS API",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "dev": "nest start --watch",
    "dev:bootstrap": "prisma migrate deploy && tsx prisma/seed.ts && nest start --watch",
    "start:prod": "node dist/main.js",
    "deploy:prod": "prisma migrate deploy && tsx prisma/seed.ts",
    "start:worker": "node dist/worker.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "openapi:generate": "nest build && ts-node --project tsconfig.json scripts/generate-openapi.ts",
    "openapi:check": "nest build && ts-node --project tsconfig.json scripts/generate-openapi.ts && git diff --exit-code openapi.json"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@aws-sdk/client-s3": "^3.1058.0",
    "@bull-board/api": "^7.1.5",
    "@bull-board/express": "^7.1.5",
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/platform-socket.io": "^10.4.0",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/throttler": "^6.2.0",
    "@nestjs/websockets": "^10.4.0",
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^10.56.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "better-auth": "^1.0.0",
    "bullmq": "^5.77.7",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "express": "^4.22.1",
    "helmet": "^7.1.0",
    "ioredis": "5.11.0",
    "multer": "^2.1.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^11.3.0",
    "prisma": "^5.22.0",
    "reflect-metadata": "^0.2.0",
    "resend": "^4.0.0",
    "rxjs": "^7.8.0",
    "socket.io": "^4.8.0",
    "tsx": "^4.19.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.2.0",
    "@nestjs/testing": "^10.4.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.14.0",
    "@types/supertest": "^6.0.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.0",
    "ts-loader": "^9.5.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "pnpm": {
    "overrides": {
      "ioredis": "5.11.0"
    }
  },
  "packageManager": "pnpm@10.29.2+sha512.bef43fa759d91fd2da4b319a5a0d13ef7a45bb985a3d7342058470f9d2051a3ba8674e629672654686ef9443ad13a82da2beb9eeb3e0221c87b8154fff9d74b8"
}
